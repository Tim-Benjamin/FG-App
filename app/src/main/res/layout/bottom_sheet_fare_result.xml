<?xml version="1.0" encoding="utf-8"?>
<!-- ============================================================
     FILE: app/src/main/res/layout/bottom_sheet_fare_result.xml
     PURPOSE: Slide-up sheet showing TroTro / Taxi / Uber fare cards.
              Matches the mockup: dark surface, gold confirm button,
              three side-by-side transport cards.
     ============================================================ -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet"
    android:paddingBottom="32dp">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_drag_handle"/>

    <!-- Origin / Destination summary fields -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilOriginSummary"
        style="@style/Widget.FareGo.TextInputLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="20dp"
        android:hint="@string/current_location"
        app:startIconDrawable="@drawable/ic_location_dot"
        app:startIconTint="@color/colorPrimary">
        <com.google.android.material.textfield.TextInputEditText
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:focusable="false"
            android:inputType="none"
            android:textColor="@color/colorOnBackground"/>
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilDestSummary"
        style="@style/Widget.FareGo.TextInputLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="10dp"
        android:hint="@string/destination"
        app:startIconDrawable="@drawable/ic_location_pin"
        app:startIconTint="@color/colorSecondaryText">
        <com.google.android.material.textfield.TextInputEditText
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:focusable="false"
            android:inputType="none"
            android:textColor="@color/colorOnBackground"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Distance label -->
    <TextView
        android:id="@+id/tvDistance"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="12dp"
        android:textColor="@color/colorSecondaryText"
        android:textSize="12sp"
        android:text="— km"/>

    <!-- ── Three transport cards ──────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="14dp">

        <!-- TroTro card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardTrotro"
            style="@style/Widget.FareGo.Card.Transport"
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            app:strokeColor="@color/colorPrimary"
            app:strokeWidth="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="10dp">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_trotro"
                    app:tint="@color/colorPrimary"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TroTro"
                    android:textColor="@color/colorOnSurface"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp"/>

                <TextView
                    android:id="@+id/tvTrotroFare"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/colorPrimary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp"
                    android:text="GH₵ — "/>

                <TextView
                    android:id="@+id/tvTrotroLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/colorSecondaryText"
                    android:textSize="10sp"
                    android:text="5 min away"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Taxi card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardTaxi"
            style="@style/Widget.FareGo.Card.Transport"
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="10dp">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_taxi"
                    app:tint="@color/colorSecondaryText"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Taxi"
                    android:textColor="@color/colorOnSurface"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp"/>

                <TextView
                    android:id="@+id/tvTaxiFare"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/colorOnSurface"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp"
                    android:text="GH₵ —"/>

                <TextView
                    android:id="@+id/tvTaxiLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/colorSecondaryText"
                    android:textSize="10sp"
                    android:text="Comfort"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Uber card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardUber"
            style="@style/Widget.FareGo.Card.Transport"
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Uber"
                    android:textColor="@color/colorOnSurface"
                    android:textSize="14sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvUberFare"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/colorOnSurface"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp"
                    android:text="GH₵ —"/>

                <TextView
                    android:id="@+id/tvUberLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/colorSecondaryText"
                    android:textSize="10sp"
                    android:text="Comfort"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <!-- Confirm gold FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btnConfirm"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="20dp"
        android:src="@drawable/ic_arrow_right"
        android:contentDescription="@string/confirm"
        app:backgroundTint="@color/colorPrimary"
        app:tint="@color/colorOnPrimary"
        app:fabSize="normal"
        app:elevation="6dp"/>

</LinearLayout>
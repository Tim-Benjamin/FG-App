<?xml version="1.0" encoding="utf-8"?>
<!-- ============================================================
     FILE: app/src/main/res/layout/fragment_home.xml
     PURPOSE: Main screen — full-screen MapLibre map with floating
              dark search card at the bottom. Matches mockup exactly:
              map fills screen, frosted dark card overlays bottom half.
     ============================================================ -->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <!-- ── Full-screen map ────────────────────────────────────── -->
    <org.maplibre.android.maps.MapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- ── Top bar: FareGo title + dashboard icon ─────────────── -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_gravity="top"
        android:paddingHorizontal="16dp"
        android:background="@drawable/bg_topbar_gradient"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <ImageButton
            android:id="@+id/btnDashboard"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_icon_button"
            android:src="@drawable/ic_person"
            android:contentDescription="My Trips"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FareGo"
            android:textColor="@color/colorOnBackground"
            android:textSize="20sp"
            android:textStyle="bold"
            android:letterSpacing="0.04"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ── Autocomplete suggestions list ──────────────────────── -->
    <ListView
        android:id="@+id/lvSuggestions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginBottom="280dp"
        android:background="@color/colorOverlay"
        android:visibility="gone"
        android:divider="@color/colorDivider"
        android:dividerHeight="0.5dp"/>

    <!-- ── Progress bar ───────────────────────────────────────── -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_gravity="center"
        android:indeterminateTint="@color/colorPrimary"
        android:visibility="gone"/>

    <!-- ── New Search button (shown in route mode) ────────────── -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnNewSearch"
        style="@style/Widget.FareGo.Button.Outline"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="76dp"
        android:text="← New Search"
        android:textSize="13sp"
        android:paddingHorizontal="20dp"
        android:visibility="gone"/>

    <!-- ── Bottom search card — matches mockup ────────────────── -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardSearch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_margin="0dp"
        app:cardBackgroundColor="@color/colorSurface"
        app:cardCornerRadius="24dp"
        app:cardElevation="16dp">

        <!-- Drag handle indicator at top of card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- Handle -->
            <View
                android:layout_width="40dp"
                android:layout_height="4dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_drag_handle"/>

            <!-- Origin field -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilOrigin"
                style="@style/Widget.FareGo.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                android:hint="@string/current_location"
                app:startIconDrawable="@drawable/ic_location_dot"
                app:startIconTint="@color/colorPrimary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etOrigin"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:inputType="text"
                    android:textColor="@color/colorOnBackground"
                    android:textSize="15sp"
                    android:imeOptions="actionNext"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Destination field -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilDestination"
                style="@style/Widget.FareGo.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="12dp"
                android:hint="@string/destination"
                app:startIconDrawable="@drawable/ic_location_pin"
                app:startIconTint="@color/colorSecondaryText">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etDestination"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:inputType="text"
                    android:textColor="@color/colorOnBackground"
                    android:textSize="15sp"
                    android:imeOptions="actionSearch"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Transport type chips + Calculate button row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                android:gravity="center_vertical">

                <!-- TroTro chip -->
                <LinearLayout
                    android:id="@+id/chipTrotro"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_transport_chip"
                    android:layout_marginEnd="8dp">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_trotro"
                        app:tint="@color/colorPrimary"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TroTro"
                        android:textColor="@color/colorOnBackground"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

                <!-- Taxi chip -->
                <LinearLayout
                    android:id="@+id/chipTaxi"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_transport_chip"
                    android:layout_marginEnd="8dp">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_taxi"
                        app:tint="@color/colorSecondaryText"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Taxi"
                        android:textColor="@color/colorOnBackground"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

                <!-- Uber chip -->
                <LinearLayout
                    android:id="@+id/chipUber"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_transport_chip"
                    android:layout_marginEnd="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Uber"
                        android:textColor="@color/colorOnBackground"
                        android:textSize="13sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="uber"
                        android:textColor="@color/colorSecondaryText"
                        android:textSize="10sp"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <!-- Calculate / Confirm gold circle button -->
                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/btnCalculateFare"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_arrow_right"
                    android:contentDescription="@string/calculate_fare"
                    app:backgroundTint="@color/colorPrimary"
                    app:tint="@color/colorOnPrimary"
                    app:fabSize="normal"
                    app:elevation="4dp"/>

            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>